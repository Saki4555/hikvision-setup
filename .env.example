# =============================================
#  HIKVISION ATTENDANCE SYSTEM - CONFIG FILE
# =============================================

# --- MySQL (XAMPP / Local DB) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=attendance_db

# --- Oracle (HRMS DB) ---
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_CONNECT_STRING=

# --- Oracle Instant Client path (REQUIRED for Oracle 11g) ---
ORACLE_INSTANT_CLIENT_PATH=C:\instantclient_23_0

# --- Polling interval (milliseconds) ---
POLL_INTERVAL_MS=10000

# --- Set to false to disable Oracle insert ---
ENABLE_ORACLE_INSERT=true