# =============================================
#  HIKVISION ATTENDANCE SYSTEM - CONFIG
# =============================================

# --- HRMS API ---
HRMS_API_URL=http://localhost:4000/endpoint
HRMS_API_TOKEN=

# --- Polling interval (milliseconds) ---
POLL_INTERVAL_MS=10000

# --- Terminals (your Hikvision devices) ---
# Add one object per device inside the array
# in_out: 1=always IN, 2=always OUT, 3=auto by time
TERMINALS=[{"ip":"xxx.xxx.xxx.xxx","in_out":3,"api_string":"http://xxx.xxx.xxx.xxx/ISAPI/AccessControl/AcsEvent?format=json","location":"Main Entrance"}]

# For multiple devices:
# TERMINALS=[{"ip":"xxx.xxx.xxx.xxx","in_out":3,"api_string":"http://xxx.xxx.xxx.xxx/ISAPI/AccessControl/AcsEvent?format=json","location":"Main Entrance"},{"ip":"xxx.xxx.xxx.xxx","in_out":2,"api_string":"http://xxx.xxx.xxx.xxx/ISAPI/AccessControl/AcsEvent?format=json","location":"Exit Gate"}]
