# =============================================
#  HIKVISION ATTENDANCE SYSTEM - CONFIG FILE
# =============================================

# --- MySQL (XAMPP / Local DB) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=attendance_db

# --- HRMS API (Oracle via your backend) ---
HRMS_API_URL=
HRMS_API_TOKEN=

# --- Polling interval (milliseconds) ---
POLL_INTERVAL_MS=10000

# --- Set to false to disable HRMS API insert ---
ENABLE_HRMS_INSERT=true

